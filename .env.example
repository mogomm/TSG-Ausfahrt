# Supabase (aus deinem Supabase-Projekt unter Settings → API)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_SERVICE_KEY=dein-service-role-key

# OpenRouteService (kostenlos auf openrouteservice.org registrieren)
# Optional – ohne Key wird Luftlinie als Fallback verwendet
ORS_API_KEY=dein-ors-api-key

# Admin-Passwort für den Admin-Bereich
ADMIN_PASSWORD=deinSicheresPasswort123

# Port (Render setzt das automatisch)
PORT=3000
